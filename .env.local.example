# Copy to .env.local for local dev, or paste into Railway → Service → Variables.
# Firebase Console → Project settings → Your apps → Web app (dissidentcodex)

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=dissidentcodex.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=dissidentcodex
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=dissidentcodex.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=977568853771
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: reCAPTCHA v3 site key for App Check (Firebase Console → App Check → Web app)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
