# Copy to .env.local and fill in from Firebase Console → Project settings → Your apps → Web app

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=dissidentcodex.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=dissidentcodex
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=dissidentcodex.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=977568853771
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional App Check (leave disabled until reCAPTCHA is configured in Firebase Console)
NEXT_PUBLIC_ENABLE_APP_CHECK=false
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=